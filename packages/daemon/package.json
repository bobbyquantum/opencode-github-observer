{
  "name": "@opencode-observer/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "opencode-observer-daemon": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "default": "./dist/logger.js"
    },
    "./service": {
      "types": "./dist/service.d.ts",
      "default": "./dist/service.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@opencode-observer/shared": "*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.0",
    "typescript": "^5.8.3"
  }
}
